# Astra local stack environment.
#
# Usage:
#   make stack-env
#   Edit MEMORIA_EMBEDDING_API_KEY and MEMORIA_EMBEDDING_BASE_URL below.
#   make stack-up
#
# `make stack-env` generates local stack secrets automatically. If you use
# plain docker compose, fill the secret values yourself.
#
# Generate secrets manually:
#   openssl rand -hex 32

# --- Docker images -----------------------------------------------------------
ASTRA_IMAGE=matrixorigin/astra:latest
MEMORIA_IMAGE=matrixorigin/memoria:latest
MATRIXONE_IMAGE=matrixorigin/matrixone:latest

# --- Host ports --------------------------------------------------------------
# Ports bind to 127.0.0.1 by default for local safety. Change *_BIND to 0.0.0.0
# only when you intentionally expose the service to other machines.
ASTRA_API_BIND=127.0.0.1
ASTRA_API_PORT=17001
MEMORIA_BIND=127.0.0.1
MEMORIA_PORT=8100
MATRIXONE_BIND=127.0.0.1
MATRIXONE_PORT=26001
MATRIXONE_DEBUG_HTTP_BIND=127.0.0.1
MATRIXONE_DEBUG_HTTP_PORT=26060

# --- MatrixOne ---------------------------------------------------------------
MATRIXONE_USER=root
MATRIXONE_PASSWORD=111
ASTRA_DATABASE=astra_runtime
#ASTRA_DATABASE_PREFIX=
ASTRA_AUTO_CREATE_DATABASE=1
MATRIXONE_DATA_VOLUME=astra-stack-matrixone-data

# --- API server --------------------------------------------------------------
# Do not enable insecure defaults outside local throwaway deployments.
ASTRA_ALLOW_INSECURE_DEFAULTS=0
ASTRA_CORS_ORIGINS=*
ASTRA_RUST_LOG=info

ASTRA_JWT_SECRET=
ASTRA_JWT_ALGORITHM=HS256
ASTRA_JWT_ACCESS_TTL_MINUTES=60
ASTRA_JWT_REFRESH_TTL_DAYS=7
ASTRA_TOKEN_ENCRYPTION_KEY=
ASTRA_BRIDGE_SECRET=

# --- Memoria -----------------------------------------------------------------
# API containers use http://memoria:8100 internally.
MEMORIA_MASTER_KEY=
MEMORIA_DB_NAME=memoria

# Required: OpenAI-compatible embedding endpoint for Memoria.
MEMORIA_EMBEDDING_PROVIDER=openai
MEMORIA_EMBEDDING_MODEL=BAAI/bge-m3
MEMORIA_EMBEDDING_DIM=1024
MEMORIA_EMBEDDING_API_KEY=
MEMORIA_EMBEDDING_BASE_URL=
MEMORIA_EMBEDDING_ENDPOINTS=
MEMORIA_RUST_LOG=info

# Optional Memoria LLM/governance settings.
#MEMORIA_LLM_API_KEY=
#MEMORIA_LLM_BASE_URL=
#MEMORIA_LLM_MODEL=gpt-4o-mini
#MEMORIA_GOVERNANCE_ENABLED=false

# --- Optional integrations ---------------------------------------------------
#GITHUB_TOKEN=
