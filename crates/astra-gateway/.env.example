# Astra Gateway — environment variables
# Copy to .env (next to gateway.yaml) and edit, or export in your shell.

# ── Storage ──
# SQLite is the default (no config needed — data goes to ~/.astra-gateway/gateway.db).
# Set this only if you want MySQL / MatrixOne instead; it overrides gateway.yaml.
# GATEWAY_DATABASE_URL=mysql://root:111@127.0.0.1:6001/astra_gateway

# ── WeChat (iLink Bot) ──
# First-time: run `astra-gateway login-weixin` to scan a QR and obtain a token.
# These env vars override the values saved in gateway.yaml / the storage backend.
WEIXIN_TOKEN=
WEIXIN_ACCOUNT_ID=

# ── WeCom (Enterprise WeChat AI Bot) ──
WECOM_BOT_ID=
WECOM_SECRET=

# ── Astra server (only for cli: type: astra) ──
# ASTRA_API_URL=http://127.0.0.1:8000
# ASTRA_USERNAME=gateway
# ASTRA_PASSWORD=gateway123

# ── Claude via AWS Bedrock (only for cli: type: claude, if you use Bedrock) ──
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# AWS_BEARER_TOKEN_BEDROCK=

# ── Logging ──
RUST_LOG=info,astra_gateway=debug
